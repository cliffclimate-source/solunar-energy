# Sanity CMS — create a free project at https://sanity.io, then fill these in .env.local
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Contact form email delivery via Resend (https://resend.com)
# Add these in Vercel → Settings → Environment Variables (do NOT commit real keys).
# RESEND_API_KEY = your Resend API key
RESEND_API_KEY=re_xxxxxxxx
# CONTACT_EMAIL  = inbox that receives enquiries (default: jimmy@solunar.my)
CONTACT_EMAIL=jimmy@solunar.my
# CONTACT_FROM   = verified sender on your domain (set after verifying solunar.my in Resend)
CONTACT_FROM=Solunar Website <noreply@solunar.my>
